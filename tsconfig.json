{
  "compilerOptions": {
    "target": "ES6", // cho phép biên dịch code Typescript sang kiểu ES6
    "module": "Node16", // Sử dụng Node16 module system thay cho commonjs mặc định
    "moduleResolution": "Node16", // Sử dụng cơ chế phân giải module mới nhất hỗ trợ `exports` trong thư mục con của Apollo
    "removeComments": true, // xóa comments khi biên dịch sang file js,
    "esModuleInterop": true, // Dùng được từ khóa import thay cho require
    "outDir": "dist"
  }
}
